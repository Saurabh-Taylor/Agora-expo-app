{
  "expo": {
    "name": "Agora",
    "slug": "Agora-expo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agoraexpoapp",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#123528",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.saurabh.agora"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F2C1F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 114,
          "resizeMode": "contain"
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Agora to access your photos when you attach evidence to a complaint.",
          "cameraPermission": "Allow Agora to use your camera when you attach evidence to a complaint.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10261B"
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-status-bar",
        {
          "hidden": false,
          "style": "light"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "921bb818-11c6-4a01-9265-c22fb4a76eb5"
      }
    }
  }
}
