# Copy to .env and fill in from your Supabase project settings (Project Settings > API).
# EXPO_PUBLIC_ vars are bundled into the client — never put a service-role key here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional client error reporting. Safe to omit for local development.
EXPO_PUBLIC_SENTRY_DSN=

# EAS/CI build secrets for Sentry source-map upload. Never prefix these with
# EXPO_PUBLIC_ and never commit their real values.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Supabase Edge Function secrets (set with `supabase secrets set`; never expose
# these as EXPO_PUBLIC_ variables or commit their real values).
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=
